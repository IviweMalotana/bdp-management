# BDP.Web (Vite + React admin dashboard) - Environment Variables
# Copy this file to .env.development (or .env.local) and fill in real values.
# Never commit real secrets.

# Backend API base URL (no trailing slash in some cases)
VITE_API_URL=http://localhost:5252/api

# Add any other public (non-secret) frontend variables below as needed.
# Example:
# VITE_APP_NAME=BDP Management
