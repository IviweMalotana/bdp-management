# BDP.Storefront (Next.js customer storefront) - Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit real secrets.

# Backend API URL (used by the storefront)
NEXT_PUBLIC_API_URL=http://localhost:5252

# Paystack public key (pk_test_... for dev, pk_live_... for production)
# This one is safe to put in client-side code, but still keep it out of the main repo.
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here
