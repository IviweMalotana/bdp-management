# BDP Storefront env — copy to /etc/bdp/storefront.env on the VPS.
# NOTE: NEXT_PUBLIC_* vars are baked in at BUILD time, so they must also be set
# in the environment where `deploy.sh` runs the build (your dev machine / CI),
# not only here. This file covers any server-side runtime vars.

NEXT_PUBLIC_API_URL=https://api.bedifferentpackaging.com
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_CHANGE_ME
PORT=3000
NODE_ENV=production
