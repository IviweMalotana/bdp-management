# BDP API env — copy to /etc/bdp/bdp-api.env on the VPS (chmod 640, owner root:deploy).
# Copy EVERY secret from your current Railway "bdp-api" service. Known keys below.
# systemd reads this verbatim (KEY=value per line, no quotes needed).

# ── Database (local VPS Postgres) ────────────────────────────────────────────
DATABASE_URL=postgresql://bdp:CHANGE_ME@localhost:5432/bdp

# ── Auth (JWT) ───────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_long_random_secret
JWT__Issuer=https://api.bedifferentpackaging.com
JWT__Audience=https://www.bedifferentpackaging.com

# ── CORS / frontend origins ──────────────────────────────────────────────────
STOREFRONT_URL=https://www.bedifferentpackaging.com
ALLOWED_ORIGINS=https://www.bedifferentpackaging.com,https://admin.bedifferentpackaging.com

# ── Payments (Paystack) ──────────────────────────────────────────────────────
Paystack__SecretKey=sk_live_CHANGE_ME
Paystack__StorefrontCallbackUrl=https://www.bedifferentpackaging.com/checkout/success
# (add any other Paystack__* keys you have in Railway, e.g. webhook secret)

# ── Transactional email (HostKing SMTP — works on the VPS, no Resend needed) ──
# Outbound SMTP is open on the VPS (unlike Railway), so send straight through
# HostKing using a mailbox you create (e.g. noreply@bedifferentpackaging.com).
# OPTIONAL: leave blank to deploy with email disabled, fill in later + restart.
Email__SmtpHost=mail.bedifferentpackaging.com   # confirm exact host in HostKing email settings
Email__SmtpPort=587                             # STARTTLS
Email__SmtpUser=noreply@bedifferentpackaging.com
Email__SmtpPassword=CHANGE_ME_mailbox_password
Email__FromAddress=noreply@bedifferentpackaging.com
Email__FromName=Be Different Packaging

# ── Shipping (YunExpress) ────────────────────────────────────────────────────
YunExpress__AppKey=CHANGE_ME
YunExpress__AppToken=CHANGE_ME

# ── Misc ─────────────────────────────────────────────────────────────────────
SEED_DATA=false
# Copy any remaining Railway vars (Google Drive, AI content keys, etc.) here too.
